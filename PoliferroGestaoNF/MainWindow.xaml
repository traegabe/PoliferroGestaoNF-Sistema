<Window x:Class="PoliferroGestaoNF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="Poliferro Comercial - Gestão de Notas Fiscais"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <Border Grid.Row="0" Background="#1B3B6A" 
                CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="POLIFERRO COMERCIAL" 
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="SISTEMA DE GESTÃO DE NOTAS FISCAIS"
                           FontSize="16" Foreground="White" 
                           VerticalAlignment="Center" Margin="20,0,0,0"/>

                <Button Grid.Column="2" Content="🔍 BUSCAR NOTAS" 
                        x:Name="btnBuscarNotas"
                        Width="150" Height="35"
                        Background="#2B4B7A" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3" Content="GERENCIAR FORNECEDORES" 
                        x:Name="btnGerenciarFornecedores"
                        Width="200" Height="35"
                        Background="#1B3B6A" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ÁREA PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO - DADOS DA NOTA -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" 
                    Padding="10" Margin="0,0,10,0" BorderBrush="#CCCCCC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="DADOS DA NOTA FISCAL" 
                               FontSize="14" FontWeight="Bold" 
                               Foreground="#1B3B6A"
                               Margin="0,0,0,15"/>

                    <!-- Fornecedor -->
                    <TextBlock Text="Fornecedor:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbFornecedor" 
                              Height="30" Margin="0,0,0,10"/>

                    <!-- Número da Nota -->
                    <TextBlock Text="Número da Nota:" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNumeroNota" 
                             Height="30" Margin="0,0,0,10"/>

                    <!-- Data da Nota - COM VALIDAÇÃO DE DATA FUTURA -->
                    <TextBlock Text="Data da Nota:" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dateNota" 
                                Height="30" Margin="0,0,0,10"
                                SelectedDateFormat="Short"
                                Language="pt-BR"
                                DisplayDateEnd="{x:Static system:DateTime.Today}"/>

                    <!-- Arquivo PDF -->
                    <TextBlock Text="Arquivo PDF:" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtCaminhoPDF" 
                                 Height="30" IsReadOnly="True"
                                 Background="#F0F0F0"/>
                        <Button Grid.Column="1" 
                                Content="SELECIONAR" 
                                x:Name="btnSelecionarPDF"
                                Width="80" Height="30" Margin="5,0,0,0"
                                Background="#1B3B6A" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <!-- Botões de Ação -->
                    <Button Content="SALVAR NOTA" 
                            x:Name="btnSalvarNota"
                            Height="40" Margin="0,20,0,0"
                            FontSize="14"
                            Background="#1B3B6A" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>

                    <Button Content="LIMPAR CAMPOS" 
                            x:Name="btnLimpar"
                            Height="30" Margin="0,10,0,0"
                            Background="Gray" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>

                    <!-- Status do WebView2 -->
                    <TextBlock x:Name="txtStatus" 
                               Text="Pronto para visualizar PDF"
                               Foreground="Green"
                               FontSize="11"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- PAINEL DIREITO - VISUALIZADOR PDF COM WEBVIEW2 -->
            <Border Grid.Column="1" Background="White" CornerRadius="5" 
                    Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PRÉ-VISUALIZAÇÃO DO DOCUMENTO" 
                               FontSize="14" FontWeight="Bold" 
                               Foreground="#1B3B6A"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Background="#E0E0E0" 
                            CornerRadius="5" BorderBrush="Gray" BorderThickness="1">
                        <Grid>
                            <wv2:WebView2 x:Name="webViewPDF" 
                                          Visibility="Collapsed"/>

                            <Border x:Name="borderSemPDF" 
                                    Background="#E0E0E0"
                                    Visibility="Visible">
                                <TextBlock Text="Nenhum PDF selecionado"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="Gray"
                                           FontSize="16"/>
                            </Border>

                            <Border x:Name="borderLoading" 
                                    Background="#E0E0E0"
                                    Visibility="Collapsed">
                                <TextBlock Text="Carregando PDF..."
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="#1B3B6A"
                                           FontSize="16"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- RODAPÉ -->
        <Border Grid.Row="2" Background="#1B3B6A" 
                CornerRadius="5" Margin="0,10,0,0" Padding="5">
            <TextBlock Text="© 2026 Poliferro Comercial - Todos os direitos reservados - DESENVOLVIDO POR GABRIEL LOPES"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>