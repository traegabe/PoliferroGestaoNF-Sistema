<Window x:Class="PoliferroGestaoNF.BuscaNotasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Notas Fiscais - Poliferro"
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <Border Grid.Row="0" Background="#1B3B6A" 
                CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <TextBlock Text="BUSCAR NOTAS FISCAIS" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- PAINEL DE BUSCA -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" 
                Padding="15" Margin="0,0,0,10" BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LINHA 1: Fornecedor e Número -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Fornecedor:" 
                               VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" 
                              x:Name="cmbFornecedorBusca"
                              Height="30" Margin="0,0,15,5"
                              IsEditable="True"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Número da Nota:" 
                               VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <TextBox Grid.Row="0" Grid.Column="3" 
                             x:Name="txtNumeroNotaBusca"
                             Height="30" Margin="0,0,0,5"/>

                    <!-- LINHA 2: Data Inicial e Data Final (CORRIGIDO) -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Data Inicial:" 
                               VerticalAlignment="Center" Margin="0,5,5,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" 
                                x:Name="dateInicial"
                                Height="30" Margin="0,5,15,0"
                                SelectedDateFormat="Short"
                                Language="pt-BR"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Data Final:" 
                               VerticalAlignment="Center" Margin="0,5,5,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="3" 
                                x:Name="dateFinal"
                                Height="30" Margin="0,5,0,0"
                                SelectedDateFormat="Short"
                                Language="pt-BR"/>
                </Grid>

                <!-- BOTÕES DE BUSCA -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" 
                            VerticalAlignment="Bottom" Margin="15,0,0,0">
                    <Button Content="BUSCAR" 
                            x:Name="btnBuscar"
                            Width="100" Height="35"
                            Background="#1B3B6A" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,10,0"/>

                    <Button Content="LIMPAR" 
                            x:Name="btnLimparBusca"
                            Width="100" Height="35"
                            Background="Gray" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA DE RESULTADOS -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" 
                Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RESULTADOS DA BUSCA" 
                           FontWeight="Bold" Foreground="#1B3B6A"
                           Margin="0,0,0,10"/>

                <!-- DataGrid para mostrar as notas -->
                <DataGrid x:Name="dgNotas" Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          RowHeight="35"
                          AlternatingRowBackground="#F0F0F0"
                          BorderThickness="0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fornecedor" 
                                            Binding="{Binding Fornecedor}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Número da Nota" 
                                            Binding="{Binding NumeroNota}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Data" 
                                            Binding="{Binding DataNota, StringFormat=dd/MM/yyyy}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Arquivo" 
                                            Binding="{Binding NomeArquivo}"
                                            Width="250"/>

                        <DataGridTextColumn Header="Caminho Completo" 
                                            Binding="{Binding CaminhoCompleto}"
                                            Width="300"/>

                        <DataGridTemplateColumn Header="Ações" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" 
                                                HorizontalAlignment="Center">
                                        <Button Content="VISUALIZAR" 
                                                Tag="{Binding CaminhoCompleto}"
                                                Click="BtnVisualizarNota_Click"
                                                Background="#1B3B6A" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Height="25" Width="70"
                                                Margin="2"/>

                                        <Button Content="ABRIR PASTA" 
                                                Tag="{Binding CaminhoCompleto}"
                                                Click="BtnAbrirPasta_Click"
                                                Background="Gray" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Height="25" Width="70"
                                                Margin="2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- RODAPÉ -->
        <Border Grid.Row="3" Background="#1B3B6A" 
                CornerRadius="5" Margin="0,10,0,0" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           x:Name="txtTotalEncontrados"
                           Text="Total de notas encontradas: 0"
                           Foreground="White" 
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        Content="FECHAR" 
                        x:Name="btnFechar"
                        Width="100" Height="30"
                        Background="White" Foreground="#1B3B6A"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>